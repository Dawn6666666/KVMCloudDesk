digraph vm_lifecycle_use_case {
    graph [bgcolor="white", rankdir=LR, ranksep=0.75, nodesep=0.5, splines=true,
           fontname="Segoe UI,Arial,Microsoft YaHei,sans-serif", fontsize=14,
           label="虚拟机生命周期状态流转图", labelloc=t];
    node [shape=box, style="filled,rounded", fillcolor="#F8FAFC", color="#CBD5E1", fontcolor="#1E293B",
          fontname="Segoe UI,Arial,Microsoft YaHei,sans-serif", fontsize=11, penwidth=1.5,
          margin="0.14,0.08"];
    edge [fontname="Segoe UI,Arial,Microsoft YaHei,sans-serif", fontsize=10, color="#64748B", penwidth=1.4,
          arrowsize=0.75];

    created [label="已定义", fillcolor="#EFF6FF", color="#3B82F6", fontcolor="#1E3A8A"];
    running [label="运行中", fillcolor="#ECFDF5", color="#10B981", fontcolor="#064E3B"];
    paused [label="已暂停", fillcolor="#FEF3C7", color="#F59E0B", fontcolor="#78350F"];
    shutoff [label="已关闭"];
    deleted [label="已删除\n定义和磁盘清理", fillcolor="#F5F3FF", color="#8B5CF6", fontcolor="#4C1D95"];
    force [label="强制断电\n异常降级", fillcolor="#FEF2F2", color="#EF4444", fontcolor="#7F1D1D"];

    created -> running [label="启动"];
    running -> paused [label="暂停"];
    paused -> running [label="恢复"];
    running -> shutoff [label="安全关机"];
    paused -> shutoff [label="关机"];
    running -> force [label="超时"];
    force -> shutoff [label="断电"];
    shutoff -> running [label="启动"];
    shutoff -> deleted [label="删除"];
}
