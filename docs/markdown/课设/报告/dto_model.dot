digraph dto_model {
    graph [bgcolor="white", rankdir=LR, ranksep=0.8, nodesep=0.5,
           fontname="Segoe UI,Arial,Microsoft YaHei,sans-serif", fontsize=14,
           label="前后端数据对象关系", labelloc=t];
    node [shape=box, style="filled,rounded", fillcolor="#F8FAFC", color="#CBD5E1", fontcolor="#1E293B",
          fontname="Segoe UI,Arial,Microsoft YaHei,sans-serif", fontsize=11, penwidth=1.5,
          margin="0.16,0.09"];
    edge [fontname="Segoe UI,Arial,Microsoft YaHei,sans-serif", fontsize=10, color="#64748B", penwidth=1.4,
          arrowsize=0.75];

    client [label="Web / Swing 客户端", fillcolor="#EFF6FF", color="#3B82F6", fontcolor="#1E3A8A"];
    request [label="操作请求对象\nCreateVmRequest\nAddImageRequest\nCreateSnapshotRequest", fillcolor="#ECFDF5", color="#10B981", fontcolor="#064E3B"];
    api [label="ApiResponse<T>\n统一响应封装", fillcolor="#FEF3C7", color="#F59E0B", fontcolor="#78350F"];
    response [label="资源响应对象\nHost / VM / Image\nNetwork / Snapshot / Storage", fillcolor="#F8FAFC", color="#CBD5E1", fontcolor="#1E293B"];

    client -> request [label="提交操作"];
    request -> api [label="后端处理"];
    api -> response [label="data"];
    response -> client [label="JSON 返回"];
}
