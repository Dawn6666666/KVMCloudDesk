digraph backend_dual_mode {
    graph [bgcolor="white", rankdir=LR, ranksep=0.7, nodesep=0.45,
           fontname="Segoe UI,Arial,Microsoft YaHei,sans-serif", fontsize=14,
           label="后端双模式服务结构", labelloc=t];
    node [shape=box, style="filled,rounded", fillcolor="#F8FAFC", color="#CBD5E1", fontcolor="#1E293B",
          fontname="Segoe UI,Arial,Microsoft YaHei,sans-serif", fontsize=11, penwidth=1.5,
          margin="0.14,0.08"];
    edge [fontname="Segoe UI,Arial,Microsoft YaHei,sans-serif", fontsize=10, color="#64748B", penwidth=1.4,
          arrowsize=0.75];

    controller [label="Controller\nREST 接口", fillcolor="#EFF6FF", color="#3B82F6", fontcolor="#1E3A8A"];
    service [label="Service 接口\nHost / VM / Network\nStorage / Snapshot"];
    mock [label="mock profile\n内存模拟数据", fillcolor="#FEF3C7", color="#F59E0B", fontcolor="#78350F"];
    libvirt_service [label="libvirt profile\n真实资源服务", fillcolor="#ECFDF5", color="#10B981", fontcolor="#064E3B"];
    jna [label="JNA 映射\nLibvirtLibrary"];
    libvirt [label="libvirt.so", fillcolor="#F5F3FF", color="#8B5CF6", fontcolor="#4C1D95"];
    kvm [label="KVM / QEMU", shape=cylinder, fillcolor="#F5F3FF", color="#8B5CF6", fontcolor="#4C1D95"];

    controller -> service;
    service -> mock [label="Windows 开发"];
    service -> libvirt_service [label="CentOS 部署"];
    libvirt_service -> jna;
    jna -> libvirt;
    libvirt -> kvm;
}
