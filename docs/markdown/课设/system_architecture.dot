digraph system_architecture {
    graph [bgcolor="white", rankdir=LR, ranksep=0.75, nodesep=0.5, compound=true,
           fontname="Segoe UI,Arial,Microsoft YaHei,sans-serif", fontsize=14,
           label="系统总体部署架构", labelloc=t];
    node [shape=box, style="filled,rounded", fillcolor="#F8FAFC", color="#CBD5E1", fontcolor="#1E293B",
          fontname="Segoe UI,Arial,Microsoft YaHei,sans-serif", fontsize=11, penwidth=1.5,
          margin="0.14,0.08"];
    edge [fontname="Segoe UI,Arial,Microsoft YaHei,sans-serif", fontsize=10, color="#64748B", penwidth=1.4,
          arrowsize=0.75];

    clients [label="客户端\nSwing / Web", fillcolor="#EFF6FF", color="#3B82F6", fontcolor="#1E3A8A"];
    api [label="REST API", fillcolor="#FEF3C7", color="#F59E0B", fontcolor="#78350F"];
    service [label="业务服务"];
    mock [label="mock 模式\n内存数据", fillcolor="#FEF3C7", color="#F59E0B", fontcolor="#78350F"];
    libvirt [label="libvirt 模式\n真实资源", fillcolor="#ECFDF5", color="#10B981", fontcolor="#064E3B"];
    jna [label="JNA"];
    so [label="libvirt.so", fillcolor="#F5F3FF", color="#8B5CF6", fontcolor="#4C1D95"];
    kvm [label="KVM / QEMU", shape=cylinder, fillcolor="#F5F3FF", color="#8B5CF6", fontcolor="#4C1D95"];

    clients -> api [label="HTTP JSON"];
    api -> service;
    service -> mock [label="Windows"];
    service -> libvirt [label="CentOS"];
    libvirt -> jna;
    jna -> so;
    so -> kvm;
}
