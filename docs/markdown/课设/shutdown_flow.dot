digraph shutdown_flow {
    graph [bgcolor="white", rankdir=LR, ranksep=0.65, nodesep=0.45,
           fontname="Segoe UI,Arial,Microsoft YaHei,sans-serif", fontsize=14,
           label="虚拟机关机轮询与超时处理流程", labelloc=t];
    node [shape=box, style="filled,rounded", fillcolor="#F8FAFC", color="#CBD5E1", fontcolor="#1E293B",
          fontname="Segoe UI,Arial,Microsoft YaHei,sans-serif", fontsize=10.5, penwidth=1.5,
          margin="0.14,0.08"];
    edge [fontname="Segoe UI,Arial,Microsoft YaHei,sans-serif", fontsize=9.5, color="#64748B", penwidth=1.4,
          arrowsize=0.75];

    start [label="点击关机", fillcolor="#EFF6FF", color="#3B82F6", fontcolor="#1E3A8A"];
    shutdown [label="发送 ACPI 信号\nvirDomainShutdown"];
    poll [label="轮询状态\n1.5 秒 / 次"];
    judge [shape=diamond, style=filled, label="关闭成功？", fillcolor="#FEF3C7", color="#F59E0B", fontcolor="#78350F"];
    success [label="刷新列表\n记录成功日志", fillcolor="#ECFDF5", color="#10B981", fontcolor="#064E3B"];
    timeout [shape=diamond, style=filled, label="超过 15 次？", fillcolor="#FEF3C7", color="#F59E0B", fontcolor="#78350F"];
    force [label="提示强制断电", fillcolor="#FEF2F2", color="#EF4444", fontcolor="#7F1D1D"];
    destroy [label="virDomainDestroy", fillcolor="#FEF2F2", color="#EF4444", fontcolor="#7F1D1D"];

    start -> shutdown;
    shutdown -> poll;
    poll -> judge;
    judge -> success [label="是"];
    judge -> timeout [label="否"];
    timeout -> poll [label="否", constraint=false];
    timeout -> force [label="是"];
    force -> destroy [label="确认"];
    destroy -> success;
}
